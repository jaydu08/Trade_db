# LLM API 配置
# 支持 OpenAI 兼容接口（OpenAI, DeepSeek, 通义千问等）

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# 或者使用 DeepSeek（更便宜）
# OPENAI_API_KEY=your_deepseek_api_key_here
# OPENAI_API_BASE=https://api.deepseek.com/v1

# 或者使用阿里通义千问
# OPENAI_API_KEY=your_qwen_api_key_here
# OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# Watchlist 兼容迁移（可选）
# 设为 1 时，系统启动若检测到旧版 watchlist 键格式，会自动备份并迁移为 MARKET:SYMBOL
# WATCHLIST_AUTO_MIGRATE=0

# LLM 模型配置
# OPENAI_MODEL=gpt-4o-mini  # OpenAI
# OPENAI_MODEL=deepseek-chat  # DeepSeek
# OPENAI_MODEL=qwen-plus  # 通义千问

# 资金流多源配置（可选）
# 默认顺序: tushare,joinquant,rqdata
# FLOW_PROVIDERS=tushare,joinquant,rqdata

# JoinQuant / JQData（可选）
# JOINQUANT_USERNAME=your_joinquant_username
# JOINQUANT_PASSWORD=your_joinquant_password
# 或使用同义变量
# JQDATA_USERNAME=your_jqdata_username
# JQDATA_PASSWORD=your_jqdata_password

# RiceQuant / RQData（可选）
# RQDATA_USERNAME=your_rqdata_username
# RQDATA_PASSWORD=your_rqdata_password
# 或使用同义变量
# RICEQUANT_USERNAME=your_ricequant_username
# RICEQUANT_PASSWORD=your_ricequant_password

# A股 Heatmap 三因子参数（可选）
# 评分 = CN_HEAT_W_PCT*涨幅强度 + CN_HEAT_W_AMOUNT*log(成交额) + CN_HEAT_W_TURNOVER*换手率
# 三个权重会在程序内自动归一化
# CN_HEAT_W_PCT=0.45
# CN_HEAT_W_AMOUNT=0.30
# CN_HEAT_W_TURNOVER=0.25
# 入池与弱市阈值（按归一化涨幅）
# CN_HEAT_NORM_MIN=0.60
# CN_HEAT_NORM_FALLBACK_MIN=0.50
# 近涨停抹平区间
# CN_HEAT_NEAR_LIMIT_LOW=0.97
# CN_HEAT_NEAR_LIMIT_HIGH=1.03
# 创业板/科创板涨幅>10%的轻量加成
# CN_HEAT_GEM_BONUS=1.10
# 候选池换手率缺失时，最多补拉市值的股票数
# CN_HEAT_TURNOVER_FETCH_CAP=220
